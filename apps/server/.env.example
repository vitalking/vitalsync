# Puerto del servidor (Railway/Render lo inyectan automáticamente)
PORT=8080
HOST=0.0.0.0

# Modo de la fuente de datos:
#   binance   -> solo datos reales de Binance (falla si está bloqueado)
#   simulated -> datos sintéticos (demo / regiones con Binance bloqueado)
#   auto      -> intenta Binance y cae a simulado si falla (recomendado)
SOURCE_MODE=auto

# Símbolos pre-cargados al iniciar (separados por coma)
PRELOAD_SYMBOLS=BTCUSDT

# Profundidad del libro enviada a la UI y frecuencia de difusión (ms)
BOOK_DEPTH=25
BOOK_BROADCAST_MS=100

# Polling de Open Interest (ms)
OI_POLL_MS=15000

# Endpoints de Binance (cambiar solo si usas un proxy regional)
BINANCE_REST_BASE=https://fapi.binance.com
BINANCE_WS_BASE=wss://fstream.binance.com

VERBOSE=true
